# PostgreSQL connection string (Prisma Postgres, Neon, Render Postgres, etc.)
DATABASE_URL="postgresql://user:password@host:5432/transitops?sslmode=require"

# JWT signing secret (use a long random string in production)
JWT_SECRET="your-secret-key"

# Server port (Render sets this automatically)
PORT=5000

# Frontend URL for CORS (your Vercel deployment URL)
FRONTEND_URL="https://your-app.vercel.app"

# Set to production when deploying
NODE_ENV=production
